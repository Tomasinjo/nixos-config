# Ignore all files by default
*

# Un-ignore directories so Git can traverse the tree
!*/

# RE-IGNORE directories that are Docker volumes.
# those are standard directory names
*-data/
*-media/
*-cache/
*-plugins/
dev/

# allow these files
!.gitignore
!**/service.nix
# frigate non-root setup
!**/overrides/*
